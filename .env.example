# Copy to .env and fill with real values. Do not commit .env.

# === Required ===
OPENROUTER_API_KEY=your_openrouter_key_here

# LangGraph checkpoint (PostgreSQL, same DB as Supabase is fine)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# === Shared Telegram API app (https://my.telegram.org) ===
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# === Per-persona credentials ===
# PREFIX = UPPERCASE(session_name from persona.yaml), e.g. kormoved → KORMOVED
# FITNESS session_name "fitness" → FITNESS_PHONE, FITNESS_API_ID, …

KORMOVED_PHONE=+70000000000
KORMOVED_API_ID=
KORMOVED_API_HASH=

FITNESS_PHONE=+70000000000
FITNESS_API_ID=
FITNESS_API_HASH=

LERA_SMM_PHONE=+70000000000
LERA_SMM_API_ID=
LERA_SMM_API_HASH=

# Bot API mode (optional)
# TELEGRAM_BOT_TOKEN=123456:your_bot_token
# KORMOVED_BOT_TOKEN=

# === Supabase (optional if using hosted API) ===
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_KEY=your_anon_or_service_key

# === Optional ===
# LOG_LEVEL=INFO
# EMBEDDING_MODEL=deepvk/USER-bge-m3
